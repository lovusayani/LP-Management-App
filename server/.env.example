PORT=5000
NODE_ENV=development
MONGO_URI=mongodb://127.0.0.1:27017/lp_management
CLIENT_URL=http://localhost:3000

JWT_ACCESS_SECRET=replace_with_secure_access_secret
JWT_REFRESH_SECRET=replace_with_secure_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=5

ADMIN_NAME=System Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Admin@12345

DEMO_LP_NAME=Demo LP User
DEMO_LP_EMAIL=lp.demo@example.com
DEMO_LP_PASSWORD=Demo@12345

FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=